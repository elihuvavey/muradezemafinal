platform :ios do
  desc "Build and upload to TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: ENV["APPSTORE_KEY_ID"],
      issuer_id: ENV["APPSTORE_ISSUER_ID"],
      key_content: ENV["APPSTORE_P8"]
    )
    cert(api_key: api_key, keychain_password: "")
    sigh(force: true, api_key: api_key)
    profile_path = lane_context[SharedValues::SIGH_PROFILE_PATH]
    increment_build_number(xcodeproj: "Runner.xcodeproj")
    sh("cd .. && flutter build ios --release --no-codesign")
    sh("cd .. && xcodebuild -exportArchive -archivePath build/ios/archive/Runner.xcarchive -exportPath build/ios/ipa -exportOptionsPlist ios/ExportOptions.plist")
    pilot(api_key: api_key, ipa: "../build/ios/ipa/Runner.ipa")
  end
end
