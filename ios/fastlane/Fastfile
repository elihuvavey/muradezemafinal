platform :ios do
  desc "Build and upload to TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: ENV["APPSTORE_KEY_ID"],
      issuer_id: ENV["APPSTORE_ISSUER_ID"],
      key_content: ENV["APPSTORE_P8"]
    )
    cert(api_key: api_key, keychain_password: "")
    sigh(force: true, api_key: api_key)
    sh("security export -k login.keychain-db -t identities -f pkcs12 -P temp123 -o certificate.p12 || true")
    sh("base64 -i certificate.p12 -o certificate.p12.base64 || true")
    increment_build_number(xcodeproj: "Runner.xcodeproj")
    gym(
      scheme: "Runner",
      export_method: "app-store",
      xcargs: "DEVELOPMENT_TEAM=K7R3D85XYA CODE_SIGN_STYLE=Automatic",
      xcodebuild_formatter: "raw"
    )
    pilot(api_key: api_key)
  end
end
