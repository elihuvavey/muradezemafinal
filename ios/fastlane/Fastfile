platform :ios do
  desc "Build and upload to TestFlight"
  lane :beta do
    create_keychain(
      name: "build.keychain",
      password: "temppass123",
      default_keychain: true,
      unlock: true,
      timeout: 3600
    )
    match(
      type: "appstore",
      app_identifier: "com.app.muradezema",
      readonly: false
    )
    increment_build_number(xcodeproj: "Runner.xcodeproj")
    gym(scheme: "Runner", export_method: "app-store")
    pilot
  end
end
