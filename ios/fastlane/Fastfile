default_platform(:ios)

platform :ios do
  desc "Build, sign, and upload to TestFlight"
  lane :beta do
    setup_ci

    api_key = app_store_connect_api_key(
      key_id: ENV["APPSTORE_KEY_ID"],
      issuer_id: ENV["APPSTORE_ISSUER_ID"],
      key_content: ENV["APPSTORE_P8_BASE64"],
      is_key_content_base64: true,
      in_house: false
    )

    match(
      type: "appstore",
      app_identifier: ENV["APPLE_BUNDLE_ID"],
      git_url: ENV["MATCH_GIT_URL"],
      api_key: api_key,
      readonly: ENV["MATCH_READONLY"] == "true"
    )

    sh("cd ../.. && flutter build ios --release --no-codesign")

    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      clean: true,
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          "com.app.muradezema" => "match AppStore com.app.muradezema"
        }
      }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end