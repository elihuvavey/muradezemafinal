platform :ios do
  lane :beta do
    api_key = app_store_connect_api_key(key_id: ENV["APPSTORE_KEY_ID"], issuer_id: ENV["APPSTORE_ISSUER_ID"], key_content: ENV["APPSTORE_P8"])
    match(api_key: api_key, type: "appstore", readonly: false)
    increment_build_number(xcodeproj: "Runner.xcodeproj")
    gym(scheme: "Runner", export_method: "app-store", xcargs: "DEVELOPMENT_TEAM=K7R3D85XYA CODE_SIGN_STYLE=Automatic")
    pilot(api_key: api_key)
  end
end