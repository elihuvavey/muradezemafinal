default_platform(:ios)

platform :ios do
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: ENV["APPSTORE_KEY_ID"],
      issuer_id: ENV["APPSTORE_ISSUER_ID"],
      key_content: ENV["APPSTORE_P8_BASE64"],
      is_key_content_base64: true,
      in_house: false
    )

    match(
      type: "appstore",
      app_identifier: ENV["APPLE_BUNDLE_ID"],
      git_url: ENV["MATCH_GIT_URL"],
      api_key: api_key,
      readonly: true
    )

    sh("cd ../.. && flutter build ios --release --no-codesign")

    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      clean: false,
      xcargs: "CODE_SIGN_STYLE=Automatic DEVELOPMENT_TEAM='#{ENV['APPLE_TEAM_ID']}'",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          ENV["APPLE_BUNDLE_ID"] => "match AppStore #{ENV['APPLE_BUNDLE_ID']}"
        }
      },
      disable_xcpretty: true
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end